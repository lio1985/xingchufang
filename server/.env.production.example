# ===================================
# 星厨房创作助手 - 生产环境配置模板
# ===================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填写真实的配置信息
# 3. 删除注释和未使用的配置
# ===================================

# ===================================
# 数据库配置（必填）
# ===================================
# 从 Supabase Dashboard -> Settings -> API 获取
COZE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
COZE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
COZE_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===================================
# JWT 认证配置（必填）
# ===================================
# 生成方法：openssl rand -base64 64
JWT_SECRET=请生成一个长随机字符串_至少32位
JWT_EXPIRES_IN=7d

# ===================================
# 应用配置
# ===================================
APP_NAME=星厨房内容创作助手
NODE_ENV=production

# ===================================
# 微信小程序配置（必填）
# ===================================
# 从微信公众平台获取
TARO_APP_WEAPP_APPID=wx你的小程序AppID
WECHAT_APP_SECRET=你的小程序AppSecret

# ===================================
# 超级管理员配置（可选）
# ===================================
# 设置为管理员的微信 openid
SUPER_ADMIN_OPENID=管理员的微信openid

# ===================================
# 生产环境域名（必填）
# ===================================
# 填写你的生产环境域名
PROJECT_DOMAIN=https://api.yourdomain.com

# ===================================
# 对象存储配置（可选）
# ===================================
# 如果需要文件上传功能，请配置以下内容

# 示例：阿里云 OSS
# COZE_S3_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# COZE_S3_ACCESS_KEY_ID=your-access-key-id
# COZE_S3_SECRET_ACCESS_KEY=your-secret-access-key
# COZE_S3_BUCKET=star-kitchen-production
# COZE_S3_REGION=oss-cn-hangzhou

# 示例：腾讯云 COS
# COZE_S3_ENDPOINT=https://cos.ap-guangzhou.myqcloud.com
# COZE_S3_ACCESS_KEY_ID=your-secret-id
# COZE_S3_SECRET_ACCESS_KEY=your-secret-key
# COZE_S3_BUCKET=star-kitchen-production
# COZE_S3_REGION=ap-guangzhou

# 示例：AWS S3
# COZE_S3_ENDPOINT=https://s3.amazonaws.com
# COZE_S3_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXXX
# COZE_S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# COZE_S3_BUCKET=star-kitchen-production
# COZE_S3_REGION=us-east-1

# 示例：Supabase Storage
# COZE_S3_ENDPOINT=https://xxxxxxxxxxxx.supabase.co/storage/v1
# COZE_S3_ACCESS_KEY_ID=your-access-key-id
# COZE_S3_SECRET_ACCESS_KEY=your-secret-access-key
# COZE_S3_BUCKET=uploads
# COZE_S3_REGION=us-east-1

# ===================================
# 端口配置
# ===================================
SERVER_PORT=3000
WEB_PORT=5000
API_TIMEOUT=30000

# ===================================
# Redis 配置（可选）
# ===================================
# 如果使用 Redis 缓存，请配置以下内容
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ===================================
# 日志配置（可选）
# ===================================
# LOG_LEVEL=info
# LOG_FILE_PATH=./logs

# ===================================
# 安全配置（可选）
# ===================================
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# RATE_LIMIT_WINDOW=15
# RATE_LIMIT_MAX_REQUESTS=100
