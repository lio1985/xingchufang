.register-page{min-height:100vh;background:-webkit-linear-gradient(315deg,#0c1929 0%,#6a11cb 50%,#2575fc 100%);background:linear-gradient(135deg,#0c1929,#6a11cb,#2575fc);display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;padding:20rpx;position:relative;overflow:hidden}.bg-decoration{position:absolute;top:0;left:0;width:100%;height:100%;overflow:hidden;z-index:0}.bg-circle{position:absolute;border-radius:50%;opacity:.15}.bg-circle-1{top:40rpx;left:40rpx;width:384rpx;height:384rpx;background:-webkit-radial-gradient(circle,rgba(59,130,246,.3) 0%,rgba(168,85,247,.2) 50%,rgba(236,72,153,.2) 100%);background:radial-gradient(circle,#3b82f64d,#a855f733,#ec489933)}.bg-circle-2{top:33.33%;right:40rpx;width:320rpx;height:320rpx;background:-webkit-radial-gradient(circle,rgba(168,85,247,.2) 0%,rgba(236,72,153,.15) 50%,rgba(239,68,68,.15) 100%);background:radial-gradient(circle,#a855f733,#ec489926,#ef444426)}.bg-circle-3{bottom:40rpx;left:25%;width:384rpx;height:384rpx;background:-webkit-radial-gradient(circle,rgba(16,185,129,.2) 0%,rgba(6,182,212,.15) 50%,rgba(59,130,246,.15) 100%);background:radial-gradient(circle,#10b98133,#06b6d426,#3b82f626)}.register-container{-webkit-flex:1;-ms-flex:1;flex:1;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;width:100%;max-width:480rpx;margin:0 auto;z-index:1}.title-text{display:block;font-size:30rpx;font-weight:700;color:#fff;background:-webkit-gradient(linear,left top,right top,from(#60a5fa),color-stop(50%,#c084fc),to(#f472b6));background:-webkit-linear-gradient(left,#60a5fa 0%,#c084fc 50%,#f472b6 100%);background:linear-gradient(90deg,#60a5fa,#c084fc,#f472b6);background-clip:text;-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:16rpx;letter-spacing:-.025em}.subtitle-text{display:block;color:rgba(255,255,255,0.50196);font-size:14rpx;margin-bottom:48rpx}.form-content{width:100%}.input-wrapper{background:rgba(255,255,255,0.10196);border-radius:16rpx;border:1rpx solid rgba(255,255,255,.2);overflow:hidden;margin-bottom:16rpx}.register-input{width:100%;height:56rpx;padding:0 20rpx;background:transparent;color:#fff;font-size:16rpx;border:none;outline:none}.register-input::-webkit-input-placeholder{color:rgba(255,255,255,0.50196);font-size:15rpx}.register-input::-moz-placeholder{color:rgba(255,255,255,0.50196);font-size:15rpx}.register-input:-ms-input-placeholder{color:rgba(255,255,255,0.50196);font-size:15rpx}.register-input::-ms-input-placeholder{color:rgba(255,255,255,0.50196);font-size:15rpx}.register-input::placeholder{color:rgba(255,255,255,0.50196);font-size:15rpx}.show-password-wrapper{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:flex-end;-ms-flex-pack:end;justify-content:flex-end;margin-bottom:16rpx}.show-password-text{color:rgba(255,255,255,0.6);font-size:14rpx}.register-button{width:100%;height:56rpx;background:-webkit-linear-gradient(315deg,#6a11cb 0%,#2575fc 100%);background:linear-gradient(135deg,#6a11cb,#2575fc);border-radius:16rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;margin-top:24rpx;-webkit-box-shadow:0 8rpx 24rpx rgba(106,17,203,.4);box-shadow:0 8rpx 24rpx rgba(106,17,203,0.4)}.register-button:active{-webkit-transform:scale(.98);-ms-transform:scale(.98);transform:scale(.98)}.register-button.loading{opacity:.7}.register-button-text{color:#fff;font-size:18rpx;font-weight:600}.back-button{position:absolute;top:16rpx;left:16rpx;padding:8rpx 16rpx;z-index:20}.back-button-text{color:rgba(255,255,255,0.70196);font-size:14rpx}.footer-links{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;margin-top:24rpx}.footer-links-text{color:rgba(255,255,255,0.50196);font-size:14rpx}.footer-links-action{color:#60a5fa;font-size:14rpx;margin-left:4rpx}
