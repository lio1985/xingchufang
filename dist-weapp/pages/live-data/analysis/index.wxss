.live-analysis-page{min-height:100vh;background:#f5f7fa}.live-analysis-page .header{background:-webkit-linear-gradient(315deg,#667eea 0%,#764ba2 100%);background:linear-gradient(135deg,#667eea,#764ba2);padding:40rpx 20rpx;text-align:center;color:#fff}.live-analysis-page .header .title{font-size:24rpx;font-weight:700;margin:16rpx 0 8rpx;display:block}.live-analysis-page .header .subtitle{font-size:14rpx;opacity:.9}.live-analysis-page .list-container{padding:16rpx;min-height:200rpx}.live-analysis-page .list-container .empty-state{text-align:center;padding:40rpx}.live-analysis-page .list-container .empty-state .empty-text{font-size:16rpx;color:#666}.live-analysis-page .list-container .empty-state .empty-tips{font-size:14rpx;color:#999;margin-top:8rpx}.live-analysis-page .list-container .live-card{background:#fff;border-radius:16rpx;padding:16rpx;margin-bottom:12rpx}.live-analysis-page .list-container .live-card .card-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between;-webkit-align-items:flex-start;-ms-flex-align:start;align-items:flex-start;margin-bottom:16rpx}.live-analysis-page .list-container .live-card .card-header .title{font-size:16rpx;font-weight:600;color:#333;margin-bottom:4rpx;display:block}.live-analysis-page .list-container .live-card .card-header .date{font-size:13rpx;color:#999}.live-analysis-page .list-container .live-card .card-header .status-badge{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;gap:4rpx;padding:4rpx 10rpx;border-radius:12rpx;font-size:12rpx}.live-analysis-page .list-container .live-card .card-header .status-badge.done{background:#f6ffed;color:#52c41a}.live-analysis-page .list-container .live-card .card-header .status-badge.pending{background:#f5f5f5;color:#999}.live-analysis-page .list-container .live-card .card-actions .action-btn{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;gap:8rpx;padding:12rpx;background:-webkit-linear-gradient(315deg,#667eea 0%,#764ba2 100%);background:linear-gradient(135deg,#667eea,#764ba2);border-radius:12rpx;color:#fff;font-weight:600}.live-analysis-page .list-container .live-card .card-actions .action-btn.primary{background:#52c41a}.live-analysis-page .list-container .live-card .card-actions .action-btn.loading{opacity:.7}.live-analysis-page .features-section{background:#fff;margin:16rpx;border-radius:16rpx;padding:20rpx}.live-analysis-page .features-section .features-title{font-size:16rpx;font-weight:600;color:#333;margin-bottom:16rpx;display:block}.live-analysis-page .features-section .feature-list .feature-item{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;gap:12rpx;padding:12rpx 0;border-bottom:1rpx solid #f0f0f0}.live-analysis-page .features-section .feature-list .feature-item:last-child{border-bottom:none}.live-analysis-page .features-section .feature-list .feature-item .name{font-size:14rpx;font-weight:600;color:#333;display:block}.live-analysis-page .features-section .feature-list .feature-item .desc{font-size:13rpx;color:#999}
