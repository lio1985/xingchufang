.live-list-page{min-height:100vh;background:#f5f7fa}.live-list-page .header{background:-webkit-linear-gradient(315deg,#667eea 0%,#764ba2 100%);background:linear-gradient(135deg,#667eea,#764ba2);padding:30rpx 20rpx;text-align:center}.live-list-page .header .title{font-size:22rpx;font-weight:700;color:#fff}.live-list-page .header .subtitle{font-size:14rpx;color:rgba(255,255,255,0.8);margin-top:8rpx}.live-list-page .list-container{padding:16rpx;min-height:calc(100vh - 120rpx)}.live-list-page .list-container .empty-state{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-webkit-align-items:center;-ms-flex-align:center;align-items:center;padding:60rpx 20rpx}.live-list-page .list-container .empty-state .empty-text{font-size:16rpx;color:#666;margin-top:16rpx}.live-list-page .list-container .empty-state .empty-tips{font-size:14rpx;color:#999;margin-top:8rpx}.live-list-page .list-container .live-card{background:#fff;border-radius:16rpx;padding:16rpx;margin-bottom:12rpx}.live-list-page .list-container .live-card .card-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between;-webkit-align-items:center;-ms-flex-align:center;align-items:center;margin-bottom:12rpx}.live-list-page .list-container .live-card .card-header .title{font-size:16rpx;font-weight:600;color:#333;-webkit-flex:1;-ms-flex:1;flex:1}.live-list-page .list-container .live-card .card-header .date{font-size:12rpx;color:#999}.live-list-page .list-container .live-card .stats-row{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-around;-ms-flex-pack:distribute;justify-content:space-around;padding:12rpx 0;border-top:1rpx solid #f0f0f0;border-bottom:1rpx solid #f0f0f0}.live-list-page .list-container .live-card .stats-row .stat-item{text-align:center}.live-list-page .list-container .live-card .stats-row .stat-item .value{font-size:16rpx;font-weight:600;color:#333;display:block}.live-list-page .list-container .live-card .stats-row .stat-item .label{font-size:12rpx;color:#999}.live-list-page .list-container .live-card .card-footer{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between;-webkit-align-items:center;-ms-flex-align:center;align-items:center;margin-top:12rpx;font-size:12rpx;color:#666}.live-list-page .list-container .loading-text,.live-list-page .list-container .no-more{text-align:center;padding:20rpx;color:#999;font-size:14rpx}
