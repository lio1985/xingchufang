.login-page{min-height:100vh;background:-webkit-linear-gradient(315deg,#0c1929 0%,#6a11cb 50%,#2575fc 100%);background:linear-gradient(135deg,#0c1929,#6a11cb,#2575fc);display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;padding:40rpx 20rpx}.login-container{width:100%;max-width:480rpx}.form-section{background:rgba(255,255,255,0.98039);border-radius:28rpx;padding:56rpx 48rpx;-webkit-box-shadow:0 24rpx 72rpx rgba(0,0,0,.35),0 12rpx 32rpx rgba(0,0,0,.25),inset 0 1rpx 0 rgba(255,255,255,.6);box-shadow:0 24rpx 72rpx rgba(0,0,0,0.34902),0 12rpx 32rpx rgba(0,0,0,0.25098),inset 0 1rpx rgba(255,255,255,0.6);-webkit-backdrop-filter:blur(20rpx);backdrop-filter:blur(20rpx);border:1rpx solid rgba(255,255,255,.2)}.form-title{text-align:center;margin-bottom:48rpx}.title-text{font-size:48rpx;font-weight:800;background:-webkit-linear-gradient(315deg,#6a11cb 0%,#2575fc 100%);background:linear-gradient(135deg,#6a11cb,#2575fc);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1.1;letter-spacing:2rpx;margin-bottom:12rpx;display:block}.title-subtitle{font-size:16rpx;color:#6a11cb;letter-spacing:3rpx;line-height:1.2;font-weight:600;text-transform:uppercase;display:block}.input-group{margin-bottom:24rpx}.input-group:last-of-type{margin-bottom:32rpx}.input{width:100%;height:60rpx;padding:0 24rpx;background:#f8f9fa;border:2rpx solid transparent;border-radius:18rpx;font-size:17rpx;color:#1a1a1a;-webkit-transition:all .3s cubic-bezier(.4,0,.2,1);transition:all .3s cubic-bezier(.4,0,.2,1);-webkit-box-shadow:inset 0 2rpx 6rpx rgba(0,0,0,.05);box-shadow:inset 0 2rpx 6rpx rgba(0,0,0,0.05098)}.input::-webkit-input-placeholder{color:#9ca3af;font-weight:400;font-size:16rpx}.input::-moz-placeholder{color:#9ca3af;font-weight:400;font-size:16rpx}.input:-ms-input-placeholder{color:#9ca3af;font-weight:400;font-size:16rpx}.input::-ms-input-placeholder{color:#9ca3af;font-weight:400;font-size:16rpx}.input::placeholder{color:#9ca3af;font-weight:400;font-size:16rpx}.input:focus{outline:none;background:#fff;border-color:#6a11cb;-webkit-box-shadow:0 0 0 4rpx rgba(106,17,203,.12),0 6rpx 16rpx rgba(106,17,203,.2),inset 0 1rpx 2rpx rgba(0,0,0,.02);box-shadow:0 0 0 4rpx rgba(106,17,203,0.12157),0 6rpx 16rpx rgba(106,17,203,0.2),inset 0 1rpx 2rpx rgba(0,0,0,0.01961);-webkit-transform:translateY(-2rpx);-ms-transform:translateY(-2rpx);transform:translateY(-2rpx)}.input-placeholder{color:#9ca3af}.password-group{position:relative}.show-password{position:absolute;right:20rpx;top:50%;-webkit-transform:translateY(-50%);-ms-transform:translateY(-50%);transform:translateY(-50%);font-size:14rpx;color:#6a11cb;font-weight:600;cursor:pointer;z-index:10;padding:6rpx 12rpx;border-radius:10rpx;-webkit-transition:all .2s;transition:all .2s;background:rgba(106,17,203,0.07843)}.login-button{width:100%;height:60rpx;background:-webkit-linear-gradient(315deg,#6a11cb 0%,#2575fc 50%,#6a11cb 100%);background:linear-gradient(135deg,#6a11cb,#2575fc,#6a11cb);background-size:200% 200%;color:#fff;font-size:19rpx;font-weight:700;border-radius:18rpx;border:none;margin-top:16rpx;-webkit-box-shadow:0 10rpx 28rpx rgba(106,17,203,.45),0 6rpx 16rpx rgba(37,117,252,.35),inset 0 1rpx 0 rgba(255,255,255,.2);box-shadow:0 10rpx 28rpx rgba(106,17,203,0.45098),0 6rpx 16rpx rgba(37,117,252,0.34902),inset 0 1rpx rgba(255,255,255,0.2);-webkit-transition:all .3s cubic-bezier(.4,0,.2,1);transition:all .3s cubic-bezier(.4,0,.2,1);-webkit-animation:gradient-shift 3s ease infinite;animation:gradient-shift 3s ease infinite;letter-spacing:1rpx}@-webkit-keyframes gradient-shift{0%,to{background-position:0% 50%}50%{background-position:100% 50%}}@keyframes gradient-shift{0%,to{background-position:0% 50%}50%{background-position:100% 50%}}.login-button:active{-webkit-transform:scale(.97);-ms-transform:scale(.97);transform:scale(.97);-webkit-box-shadow:0 6rpx 16rpx rgba(106,17,203,.35),inset 0 2rpx 4rpx rgba(0,0,0,.1);box-shadow:0 6rpx 16rpx rgba(106,17,203,0.34902),inset 0 2rpx 4rpx rgba(0,0,0,0.10196)}.login-button.loading{opacity:.8;-webkit-animation:none;animation:none}.login-button:after{border:none}.footer-links{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;margin-top:40rpx;gap:20rpx;padding-top:32rpx;border-top:1rpx solid rgba(0,0,0,.08)}.footer-link{font-size:16rpx;color:#6a11cb;font-weight:600;line-height:1.2;position:relative;-webkit-transition:all .2s;transition:all .2s;padding:6rpx 12rpx;border-radius:8rpx}.footer-link:after{content:"";position:absolute;bottom:0;left:50%;width:0;height:2rpx;background:-webkit-gradient(linear,left top,right top,from(#6a11cb),to(#2575fc));background:-webkit-linear-gradient(left,#6a11cb,#2575fc);background:linear-gradient(90deg,#6a11cb,#2575fc);-webkit-transition:all .3s;transition:all .3s;-webkit-transform:translateX(-50%);-ms-transform:translateX(-50%);transform:translate(-50%)}.footer-divider{font-size:16rpx;color:#d1d5db;font-weight:400;line-height:1.2;padding:0 8rpx}
