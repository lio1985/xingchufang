# 数据库配置（使用 Supabase）
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# 对象存储配置（AWS S3 / 阿里云 OSS / 腾讯云 COS / MinIO）
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=your_bucket_name
S3_REGION=us-east-1

# JWT 配置
JWT_SECRET=your_jwt_secret_key_please_change_this_to_a_long_random_string

# 微信小程序配置
TARO_APP_WEAPP_APPID=your_wechat_mini_program_appid
WECHAT_APP_SECRET=your_wechat_mini_program_secret

# 超级管理员配置（设置为管理员的微信 openid）
SUPER_ADMIN_OPENID=your_admin_openid

# 生产环境配置
NODE_ENV=production
PROJECT_DOMAIN=https://api.xingchufang.cn

# Web Search & LLM 配置（如果使用 coze-coding-dev-sdk）
# COZE_API_KEY=your_coze_api_key
